<?xml version="1.0" encoding="UTF-8" ?>
<CycloneDDS xmlns="https://cdds.io/config">
    <Domain id="any">
        <General>
            <Interfaces>
                <!-- GPU PC ethernet interface -->
                <NetworkInterface name="enP2p1s0"/>
            </Interfaces>
            <AllowMulticast>true</AllowMulticast>
            <MaxMessageSize>65535B</MaxMessageSize>
            <FragmentSize>4000B</FragmentSize>
        </General>
        <Discovery>
            <Peers>
                <!-- Robot PC direct-link IP -->
                <Peer address="192.168.100.128"/>
            </Peers>
        </Discovery>
        <Internal>
            <SocketReceiveBufferSize min="128MB"/>
            <Watermarks>
                <WhcHigh>8MB</WhcHigh>
            </Watermarks>
        </Internal>
    </Domain>
</CycloneDDS>
