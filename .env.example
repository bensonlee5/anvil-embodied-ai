# ROS2 distributed inference environment
# Copy to .env and edit for your setup:  cp .env.example .env

# ── Deployment mode ──────────────────────────────────────────────────────────
#
# Single-PC CycloneDDS — default (inference + workcell on same machine):
#   ROS_DOMAIN_ID=1          # must match anvil-loader's ROS_DOMAIN_ID
#   RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
#   CYCLONEDDS_URI=file:///workspace/configs/cyclonedds/single_pc.xml
#   (also set ENABLE_CYCLONEDDS=true + CYCLONEDDS_PEER_IP=127.0.0.1 in anvil-loader)
#
# Single-PC Fast DDS — opt-in (same machine, no CycloneDDS):
#   ROS_DOMAIN_ID=1
#   RMW_IMPLEMENTATION=rmw_fastrtps_cpp
#   CYCLONEDDS_URI=                      # ignored under Fast DDS
#   (also set ENABLE_CYCLONEDDS=false in anvil-loader so both sides match)
#
# Two-PC CycloneDDS (GPU PC separate from robot PC):
#   ROS_DOMAIN_ID=1          # must match anvil-loader's ROS_DOMAIN_ID
#   RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
#   CYCLONEDDS_URI=file:///workspace/configs/cyclonedds/two_pc_gpu.xml
#   (also set ENABLE_CYCLONEDDS=true + CYCLONEDDS_PEER_IP=<gpu_pc_ip> in anvil-loader)
#
# ⚠ Both sides must use the same RMW — mixing Fast DDS and CycloneDDS = no discovery.
# ─────────────────────────────────────────────────────────────────────────────
ROS_DOMAIN_ID=1
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///workspace/configs/cyclonedds/single_pc.xml

# MODEL_PATH is a HOST path — mounted read-only into the container at /workspace/model.
# Must be an absolute path or start with ./  (bare relative paths cause Docker errors).
# Point to a checkpoint dir; pretrained_model/ and HF cache snapshots/ are auto-detected.
# View or set local checkpoints with:
#   ./scripts/inference_model.py list
#   ./scripts/inference_model.py set lego-in-cup/act:last
MODEL_PATH=./model_zoo/my-task/checkpoints/last

# CONFIG_FILE — host path to inference YAML config.
CONFIG_FILE=./configs/lerobot_control/inference_default.yaml

# INFERENCE_ARM — required for real-robot startup. The launcher validates
# observation and command mappings before starting the model.
# Options: left | right | bimanual
INFERENCE_ARM=

# ACTION_TYPE — auto-detected from MODEL_PATH/anvil_config.json at launch time.
# Override here only if auto-detection fails (e.g. checkpoint has no anvil_config.json).
# Options: absolute | delta_obs_t | delta_sequential
ACTION_TYPE=absolute

# Docker image tag (used by docker-compose.yml)
IMAGE_TAG=latest

# lerobot version pinned in the Docker image
LEROBOT_VERSION=0.6.0

# Optional lerobot extras — comma-separated. Diffusion is the default when unset so
# diffusion checkpoints load without extra setup. ACT can set this empty to minimize the image.
# Rebuild the image after changing this:  docker compose build
# Examples:
#   diffusion                              -> diffusion policies (default)
#   smolvla                                -> SmolVLA inference
#   pi,smolvla                             -> Pi0/Pi0.5 + SmolVLA inference
#   molmoact2,groot,evo1                   -> RTC-capable foundation policies
#   multi_task_dit,fastwam,vla_jepa        -> synchronous foundation policies
#   diffusion,smolvla,molmoact2,groot,evo1 -> one broader inference image
LEROBOT_EXTRAS=diffusion

# HF_CACHE — host path to HuggingFace model cache.
# Required for language-conditioned/foundation policies that load tokenizers or
# pretrained backbones at runtime. ACT and Diffusion models do not need this.
HF_CACHE=~/.cache/huggingface

# Set to true to skip model loading and just subscribe to topics + log FPS.
# Useful for verifying DDS connectivity without a GPU or checkpoint.
# Equivalent to passing --echo-topic-only to run_inference.sh.
ECHO_TOPIC_ONLY=false

# Set to true to enable the inference monitor node (records per-step CSV + PNG report).
# Equivalent to passing --monitor-enable to run_inference.sh.
# Note: run_inference.sh --monitor also pre-creates the output dir and auto-plots on exit.
MONITOR_ENABLE=false

# Debug mode — enables extra metrics: action smoothness, queue depth stats, Action FPS
DEBUG=false
