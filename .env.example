# ROS2 distributed inference environment
# Copy to .env and edit for your setup:  cp .env.example .env

# ROS domain ID — must match the Robot PC. Leave empty for localhost-only mode.
ROS_DOMAIN_ID=1

# CycloneDDS middleware (required for cross-machine discovery)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
CYCLONEDDS_URI=file:///workspace/configs/cyclonedds/gpu_pc.xml

# Model path inside the container (model_zoo/ is mounted read-only)
# For testing: /workspace/model_zoo/test/pretrained_model
MODEL_PATH=/workspace/model_zoo/my_model
CONFIG_FILE=/workspace/configs/lerobot_control/inference_default.yaml

# Docker image tag (used by docker-compose.yml)
IMAGE_TAG=latest

# lerobot version pinned in the Docker image
LEROBOT_VERSION=0.5.0

# Optional lerobot extras — comma-separated, empty for ACT/Diffusion (no extras needed)
# Rebuild the image after changing this:  docker compose build
# Examples:
#   smolvla              → for SmolVLA inference
#   smolvla,peft         → SmolVLA + LoRA fine-tuned models
LEROBOT_EXTRAS=

# Set to true to skip model loading and just monitor FPS (for testing DDS connectivity)
MONITOR_ONLY=false

# ----------------------------------------------------------------------------
# Neuracore inference (alternate backend — runs the 'neuracore-inference'
# service via `docker compose --profile neuracore up neuracore-inference`).
# Use this when your trained policy is a neuracore .nc.zip instead of a
# LeRobot checkpoint. Requires a Neuracore API key.
# ----------------------------------------------------------------------------

# Auth — required. Get this from the Neuracore dashboard.
NEURACORE_API_KEY=

# Model source. Set exactly one; model_file takes precedence.
# model_file: path inside the container (model_zoo/ is mounted read-only)
NEURACORE_MODEL_FILE=/workspace/model_zoo/my_model/model.nc.zip
NEURACORE_TRAIN_RUN_NAME=

# Robot embodiment name — must match the one used for data collection.
NEURACORE_ROBOT_NAME=anvil_openarm

# Control loop rate. 30 Hz is a safe default matching data collection.
NEURACORE_INFERENCE_RATE_HZ=30.0

# Skip neuracore's P2P webrtc listeners (we log locally + predict locally).
NEURACORE_CONSUME_LIVE_DATA=0

# Pinned neuracore version (must include the [ml] extras — the Dockerfile
# installs `neuracore[ml]` at this version).
NEURACORE_VERSION=11.0.0
NEURACORE_IMAGE_TAG=latest
